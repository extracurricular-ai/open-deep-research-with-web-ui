# API Keys
SERPAPI_API_KEY=your_serpapi_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here  # For DeepSeek Chat and Reasoner models
HF_TOKEN=your_huggingface_token_here  # Only required for run_gaia.py (dataset downloading)
META_SOTA_API_KEY=your_metaso_api_key_here  # For MetaSo search engine

# Search Engine Configuration
# Options: DDGS (DuckDuckGo, no API key), META_SOTA (MetaSo, requires API key)
# Can specify multiple as fallback: DDGS,META_SOTA or META_SOTA,DDGS
SEARCH_ENGINE=DDGS

# Configuration
DEBUG=False
LOG_LEVEL=INFO

# Other Settings
TIMEOUT=30
MAX_RETRIES=3
