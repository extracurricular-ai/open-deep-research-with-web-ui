# Server Config UI (set to true to enable server config management via Web UI)
ENABLE_CONFIG_UI=false
CONFIG_ADMIN_PASSWORD=change_me_to_a_secure_password

# API Keys (fallback — prefer odr-config.json or client-side settings)
SERPAPI_API_KEY=your_serpapi_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here  # For DeepSeek Chat and Reasoner models
HF_TOKEN=your_huggingface_token_here  # Only required for run_gaia.py (dataset downloading)
META_SOTA_API_KEY=your_metaso_api_key_here  # For MetaSo search engine

# Logging
DEBUG=False
LOG_LEVEL=INFO
